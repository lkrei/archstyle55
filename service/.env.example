# core
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000

# postgres + pgvector
# Local: pgvector/pgvector:pg16; production: Neon URL
DATABASE_URL=postgresql+asyncpg://archstyle:archstyle@postgres:5432/archstyle
DATABASE_URL_SYNC=postgresql+psycopg://archstyle:archstyle@postgres:5432/archstyle

# redis
# Local: redis://redis:6379/0; production: rediss://default:<token>@<host>:6379
REDIS_URL=redis://redis:6379/0

# huggingface
HF_TOKEN=
HF_ORG=kkkaredaw
HF_MODEL_REPO=kkkaredaw/archstyle55-backbones
HF_DATASET_REPO=kkkaredaw/archstyle55-scraped
HF_SPACE_REPO=kkkaredaw/archstyle55-backend

# weights & biases
WANDB_API_KEY=
WANDB_PROJECT=archstyle-vkr

# prefect cloud
PREFECT_API_URL=
PREFECT_API_KEY=

# frontend
STREAMLIT_THEME_BASE=light
PUBLIC_BACKEND_URL=http://localhost:8000

# ml
MODEL_CACHE_DIR=/data/models
MODEL_LRU_SLOTS=3
INFERENCE_DEVICE=cpu
TORCH_NUM_THREADS=4

# security / rate limit
RATE_LIMIT_PREDICT=30/minute
ALLOWED_ORIGINS=*

# licensed image fetcher (Wikimedia Commons + Openverse)
SCRAPER_USER_AGENT=archstyle55-research-bot/1.0 (mailto:research@example.org)
SCRAPER_MAX_PER_JOB=100
